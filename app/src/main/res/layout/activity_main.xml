<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="PrecisionTap (정밀 자동 터치)"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnA11y"
            android:text="① 접근성 권한 켜기"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <Button
            android:id="@+id/btnOverlay"
            android:text="② 다른 앱 위 표시 권한"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#888" android:layout_marginVertical="12dp"/>

        <TextView android:text="트리거 시각 (HH:MM:SS.mmm) — 24시간"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <EditText android:id="@+id/etHour" android:hint="HH" android:inputType="number"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <EditText android:id="@+id/etMinute" android:hint="MM" android:inputType="number"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <EditText android:id="@+id/etSecond" android:hint="SS" android:inputType="number"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <EditText android:id="@+id/etMillisecond" android:hint="mmm" android:inputType="number"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"/>
        </LinearLayout>

        <TextView android:text="터치 좌표 (px, 디바이스 절대좌표)"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <EditText android:id="@+id/etX" android:hint="X" android:inputType="numberDecimal"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <EditText android:id="@+id/etY" android:hint="Y" android:inputType="numberDecimal"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnPickCoord"
            android:text="📍 화면 탭으로 좌표 잡기"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView android:text="반복 횟수 / 간격(ms)  — 단발은 1, 0"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <EditText android:id="@+id/etRepeat" android:hint="횟수" android:text="1" android:inputType="number"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <EditText android:id="@+id/etInterval" android:hint="간격(ms)" android:text="0" android:inputType="number"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnStart"
            android:text="③ 타이머 시작"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_marginTop="12dp"
            android:textSize="14sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_marginTop="20dp"
            android:textSize="12sp"
            android:textColor="#999"
            android:text="• 화면 탭으로 좌표 잡기: 5초 후 활성화되니 그동안 대상 앱으로 이동하세요.\n• 시계 정밀도는 단말기 시스템 시간(NTP) 기준입니다.\n• 백그라운드 실행 제한이 있는 일부 기기는 '자동 시작 허용'이 필요할 수 있습니다."
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
